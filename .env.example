# Public URL of the backend API as the *browser* will reach it.
# This value is inlined into the JS bundle at BUILD time (NEXT_PUBLIC_*
# vars are not read at runtime) — change it here and re-deploy.
#
# Local dev:    http://localhost:3000/api/v1
# VPS, same host as backend, no domain yet:
#               http://<vps-public-ip>:3000/api/v1
# VPS, behind a domain + reverse proxy (recommended for production):
#               https://api.your-domain.com/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
